---
import PageLayout from '../../layouts/PageLayout.astro';
import SEOHead from '../../components/astro/SEOHead.astro';
import LogoBar from '../../components/astro/LogoBar.astro';
import StatsCounter from '../../components/astro/StatsCounter.astro';
import FeatureCard from '../../components/astro/FeatureCard.astro';
import CTASection from '../../components/astro/CTASection.astro';
import FAQ from '../../components/astro/FAQ.astro';
import MascotteSection from '../../components/astro/MascotteSection.astro';
import ScrollReveal from '../../components/animations/ScrollReveal.astro';
import HeroPhone3D from '../../components/react/HeroPhone3D.tsx';
import { t } from '../../i18n/utils';
import { generateOrganizationSchema, generateWebSiteSchema } from '../../lib/seo';

const locale = 'fr';

// Hero
const heroTitle = await t(locale, 'home', 'hero.title');
const heroSubtitle = await t(locale, 'home', 'hero.subtitle');
const heroBaseline = await t(locale, 'home', 'hero.baseline');
const heroCta = await t(locale, 'home', 'hero.cta-primary');
const heroCtaSecondary = await t(locale, 'home', 'hero.cta-secondary');
const heroMicroText = await t(locale, 'home', 'hero.micro-text');

// Stats
const statsTitle = await t(locale, 'home', 'stats.title');

// Benefits
const benefitsTitle = await t(locale, 'home', 'benefits.title');
const benefits = [];
for (let i = 0; i < 4; i++) {
  benefits.push({
    title: await t(locale, 'home', `benefits.items.${i}.title`),
    subtitle: await t(locale, 'home', `benefits.items.${i}.subtitle`),
    description: await t(locale, 'home', `benefits.items.${i}.description`),
    proof: await t(locale, 'home', `benefits.items.${i}.proof`),
  });
}

// Offers
const offersTitle = await t(locale, 'home', 'offers.title');
const offers = [];
for (let i = 0; i < 3; i++) {
  offers.push({
    title: await t(locale, 'home', `offers.items.${i}.title`),
    description: await t(locale, 'home', `offers.items.${i}.description`),
    cta: await t(locale, 'home', `offers.items.${i}.cta`),
    link: await t(locale, 'home', `offers.items.${i}.link`),
  });
}

// How it works summary
const hiwTitle = await t(locale, 'home', 'how-it-works-summary.title');
const hiwCta = await t(locale, 'home', 'how-it-works-summary.cta');
const hiwSteps = [];
for (let i = 0; i < 4; i++) {
  hiwSteps.push({
    title: await t(locale, 'home', `how-it-works-summary.steps.${i}.title`),
    description: await t(locale, 'home', `how-it-works-summary.steps.${i}.description`),
  });
}

// Social proof
const socialTitle = await t(locale, 'home', 'social-proof.title');
const partnersSubtitle = await t(locale, 'home', 'social-proof.partners.title');
const techPartners = [];
for (let i = 0; i < 4; i++) {
  techPartners.push({
    name: await t(locale, 'home', `social-proof.partners.items.${i}.name`),
    description: await t(locale, 'home', `social-proof.partners.items.${i}.description`),
  });
}

// Mascotte
const mascotteText = await t(locale, 'home', 'mascotte.text');
const mascotteCta = await t(locale, 'home', 'mascotte.cta');

// FAQ
const faqTitle = await t(locale, 'home', 'faq.title');
const faqItems = [];
for (let i = 0; i < 4; i++) {
  faqItems.push({
    question: await t(locale, 'home', `faq.items.${i}.question`),
    answer: await t(locale, 'home', `faq.items.${i}.answer`),
  });
}

// Final CTA
const finalCtaTitle = await t(locale, 'home', 'final-cta.title');
const finalCtaSubtitle = await t(locale, 'home', 'final-cta.subtitle');
const finalCtaPrimary = await t(locale, 'home', 'final-cta.cta-primary');
const finalCtaSecondary = await t(locale, 'home', 'final-cta.cta-secondary');

// SEO
const metaTitle = await t(locale, 'home', 'meta.title');
const metaDescription = await t(locale, 'home', 'meta.description');
const orgSchema = generateOrganizationSchema();
const siteSchema = generateWebSiteSchema(locale);
---

<PageLayout title={metaTitle} description={metaDescription} locale={locale}>
  <SEOHead slot="head" locale={locale} page="home" jsonLd={[orgSchema, siteSchema]} />

  <!-- ========== 1. HERO ========== -->
  <section class="relative overflow-hidden bg-[var(--cream)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 lg:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <ScrollReveal direction="left">
          <div class="max-w-xl">
            <span class="inline-block text-xs font-medium text-[var(--walnut)] tracking-[0.15em] uppercase mb-4">
              {heroBaseline}
            </span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-normal text-[var(--text-primary)] leading-tight tracking-[0.02em] mb-6">
              {heroTitle}
            </h1>
            <p class="text-lg md:text-xl text-[var(--text-secondary)] leading-relaxed mb-8">
              {heroSubtitle}
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/fr/contact" class="inline-flex items-center justify-center bg-[var(--terracotta)] text-[var(--parchment)] px-8 py-4 rounded-[3px] font-medium uppercase tracking-[0.06em] hover:bg-[var(--clay)] transition-colors text-center">
                {heroCta}
              </a>
              <a href="/fr/contact" class="inline-flex items-center justify-center border border-[var(--walnut)] text-[var(--walnut)] px-8 py-4 rounded-[3px] font-semibold hover:bg-[var(--walnut)] hover:text-[var(--parchment)] transition-colors text-center text-sm">
                {heroCtaSecondary}
              </a>
            </div>
            <p class="mt-3 text-sm text-[var(--text-secondary)] opacity-70">{heroMicroText}</p>
          </div>
        </ScrollReveal>

        <ScrollReveal direction="right" delay={0.2}>
          <div class="w-full h-[400px] md:h-[500px] lg:h-[600px]">
            <HeroPhone3D client:only="react" />
          </div>
        </ScrollReveal>
      </div>
    </div>
    <div class="absolute top-1/2 right-0 -translate-y-1/2 w-[600px] h-[600px] border-[6px] border-[var(--sage-light)] rounded-full pointer-events-none opacity-30" aria-hidden="true"></div>
  </section>

  <!-- ========== 2. STATS ========== -->
  <div class="bg-[var(--bg-beige)]">
    <ScrollReveal>
      <StatsCounter locale={locale} title={statsTitle} />
    </ScrollReveal>
  </div>

  <!-- ========== 3. BENEFITS ========== -->
  <section class="py-16 md:py-24 bg-[var(--sage)] relative overflow-hidden">
    <!-- MCM geometric accent -->
    <div class="absolute top-8 right-8 w-48 h-48 rounded-full border-4 border-[var(--forest)] opacity-30 pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <ScrollReveal>
        <div class="text-center mb-12 md:mb-16">
          <h2 class="text-3xl md:text-4xl font-normal text-[var(--cream)] tracking-[0.02em]">
            {benefitsTitle}
          </h2>
        </div>
      </ScrollReveal>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {benefits.map((b, i) => (
          <ScrollReveal delay={i * 0.1}>
            <div class="bg-[var(--cream)] rounded-[3px] p-8 border border-[var(--walnut)] h-full">
              <p class="text-sm font-medium text-[var(--walnut)] mb-2">{b.subtitle}</p>
              <h3 class="text-xl font-normal text-[var(--espresso)] mb-3">{b.title}</h3>
              <p class="text-[var(--walnut)] leading-relaxed mb-4">{b.description}</p>
              <p class="text-sm text-[var(--forest)] italic">{b.proof}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== 4b. LOGO BAR ========== -->
  <div class="bg-[var(--sand)]">
    <LogoBar locale={locale} bg="beige" />
  </div>

  <!-- ========== 5. VERTICALS ========== -->
  <section class="py-16 md:py-24 bg-[var(--bg-beige)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <div class="text-center mb-12 md:mb-16">
          <h2 class="text-3xl md:text-4xl font-normal text-[var(--text-primary)] tracking-[0.02em]">
            {offersTitle}
          </h2>
        </div>
      </ScrollReveal>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {offers.map((offer, i) => (
          <ScrollReveal delay={i * 0.15}>
            <div class="bg-[var(--bg-primary)] rounded-[3px] p-8 border border-[var(--walnut)] hover:shadow-md transition-shadow flex flex-col h-full">
              <h3 class="text-xl font-normal text-[var(--text-primary)] mb-3">{offer.title}</h3>
              <p class="text-[var(--text-secondary)] leading-relaxed mb-6 flex-grow">{offer.description}</p>
              <a href={`/fr/${offer.link === 'collectivity' ? 'collectivite' : offer.link}`} class="inline-flex items-center text-[var(--forest)] font-semibold hover:underline">
                {offer.cta}
              </a>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== 6. HOW IT WORKS SUMMARY ========== -->
  <section class="py-16 md:py-24 bg-[var(--sand)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <div class="text-center mb-12 md:mb-16">
          <h2 class="text-3xl md:text-4xl font-normal text-[var(--espresso)] tracking-[0.02em]">
            {hiwTitle}
          </h2>
        </div>
      </ScrollReveal>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {hiwSteps.map((step, i) => (
          <ScrollReveal delay={i * 0.15}>
            <div class="relative text-center">
              <div class="w-16 h-16 rounded-full bg-[var(--sage)] text-[var(--parchment)] flex items-center justify-center mx-auto mb-6">
                <span class="text-2xl font-normal">{String(i + 1).padStart(2, '0')}</span>
              </div>
              {i < 3 && (
                <div class="hidden lg:block absolute top-8 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-0.5 bg-[var(--walnut)]/20" aria-hidden="true" />
              )}
              <h3 class="text-lg font-normal text-[var(--espresso)] mb-2">{step.title}</h3>
              <p class="text-sm text-[var(--walnut)] leading-relaxed">{step.description}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/fr/comment-ca-marche" class="inline-flex items-center text-[var(--forest)] font-semibold hover:underline">
          {hiwCta}
        </a>
      </div>
    </div>
  </section>

  <!-- ========== 7. SOCIAL PROOF ========== -->
  <section class="py-16 md:py-24 bg-[var(--bg-beige)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <div class="text-center mb-12 md:mb-16">
          <h2 class="text-3xl md:text-4xl font-normal text-[var(--text-primary)] tracking-[0.02em]">
            {socialTitle}
          </h2>
        </div>
      </ScrollReveal>

      <ScrollReveal>
        <div class="max-w-3xl mx-auto mb-16">
          <div class="bg-[var(--bg-primary)] rounded-[3px] p-8 border border-[var(--border-color)] text-center">
            <p class="text-[var(--text-secondary)] italic">Emplacement réservé pour témoignage commerçant.</p>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={0.2}>
        <h3 class="text-xl font-normal text-[var(--text-primary)] text-center mb-8">{partnersSubtitle}</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto">
          {techPartners.map((partner) => (
            <div class="bg-[var(--bg-primary)] rounded-[3px] p-6 text-center border border-[var(--border-color)]">
              <p class="font-semibold text-[var(--text-primary)] text-sm mb-1">{partner.name}</p>
              <p class="text-xs text-[var(--text-secondary)]">{partner.description}</p>
            </div>
          ))}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- ========== 8. MASCOTTE ========== -->
  <div class="bg-[var(--sage)]">
    <ScrollReveal>
      <MascotteSection text={mascotteText} ctaText={mascotteCta} ctaHref="#" />
    </ScrollReveal>
  </div>

  <!-- ========== 9. FAQ ========== -->
  <div class="bg-[var(--bg-beige)]">
    <ScrollReveal>
      <FAQ items={faqItems} title={faqTitle} />
    </ScrollReveal>
  </div>

  <!-- ========== 10. PRE-FOOTER CTA ========== -->
  <ScrollReveal>
    <CTASection
      title={finalCtaTitle}
      subtitle={finalCtaSubtitle}
      ctaText={finalCtaPrimary}
      ctaHref="/fr/contact"
      secondaryCtaText={finalCtaSecondary}
      secondaryCtaHref="/fr/contact"
    />
  </ScrollReveal>
</PageLayout>
