---
import type { PricingTier } from '@data/pricing-tiers';
import type { Locale } from '@i18n/config';

interface Props {
  tier: PricingTier;
  locale: Locale;
}

const { tier, locale } = Astro.props;

const popularLabel: Record<Locale, string> = {
  fr: 'Le plus populaire',
  en: 'Most popular',
};
---

<div class:list={['pricing-card', { 'pricing-card--highlighted': tier.highlighted }]}>
  {tier.highlighted && (
    <span class="pricing-card__badge">{popularLabel[locale]}</span>
  )}

  <div class="pricing-card__header">
    <h3 class="pricing-card__name">{tier.name[locale]}</h3>
    <p class="pricing-card__desc">{tier.description[locale]}</p>
  </div>

  <ul class="pricing-card__features">
    {tier.features.map((feature) => (
      <li class:list={['pricing-card__feature', { 'pricing-card__feature--excluded': !feature.included }]}>
        {feature.included ? (
          <svg class="pricing-card__icon pricing-card__icon--check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        ) : (
          <svg class="pricing-card__icon pricing-card__icon--dash" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
        )}
        <span>{feature.name[locale]}</span>
      </li>
    ))}
  </ul>

  <div class="pricing-card__footer">
    <a
      href={`/${locale}/contact`}
      class:list={['pricing-card__cta', { 'pricing-card__cta--primary': tier.highlighted }]}
    >
      {tier.cta[locale]}
    </a>
  </div>
</div>

<style>
  .pricing-card {
    display: flex;
    flex-direction: column;
    background: var(--sand);
    border: 1px solid var(--walnut);
    border-radius: 3px;
    padding: var(--space-8, 2rem);
    position: relative;
    transition: box-shadow var(--duration-normal, 300ms) var(--ease-out-expo);
  }

  .pricing-card:hover {
    box-shadow: 4px 4px 0 var(--walnut);
  }

  .pricing-card--highlighted {
    border-color: var(--terracotta);
    border-width: 2px;
  }

  .pricing-card--highlighted:hover {
    box-shadow: 4px 4px 0 var(--terracotta);
  }

  .pricing-card__badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--terracotta);
    color: var(--parchment);
    font-family: var(--font-body, sans-serif);
    font-size: var(--text-xs, 0.8125rem);
    font-weight: var(--font-weight-medium, 500);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: var(--space-1, 0.25rem) var(--space-4, 1rem);
    border-radius: 3px;
    white-space: nowrap;
  }

  .pricing-card__header {
    text-align: center;
    margin-bottom: var(--space-6, 1.5rem);
    padding-bottom: var(--space-6, 1.5rem);
    border-bottom: 1px solid var(--border-color);
  }

  .pricing-card__name {
    font-family: var(--font-display, serif);
    font-size: var(--text-2xl, 1.625rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    margin: 0 0 var(--space-2, 0.5rem);
  }

  .pricing-card__desc {
    font-size: var(--text-sm, 0.875rem);
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.75;
  }

  .pricing-card__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
    flex-grow: 1;
  }

  .pricing-card__feature {
    display: flex;
    align-items: center;
    gap: var(--space-2, 0.5rem);
    font-size: var(--text-sm, 0.875rem);
    color: var(--text-primary);
  }

  .pricing-card__feature--excluded {
    color: var(--text-secondary);
    opacity: 0.6;
  }

  .pricing-card__icon--check {
    color: var(--sage);
    flex-shrink: 0;
  }

  .pricing-card__icon--dash {
    color: var(--text-secondary);
    flex-shrink: 0;
    opacity: 0.4;
  }

  .pricing-card__footer {
    margin-top: var(--space-8, 2rem);
    text-align: center;
  }

  .pricing-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: var(--space-3, 0.75rem) var(--space-6, 1.5rem);
    border: 1.5px solid var(--walnut);
    border-radius: 3px;
    font-family: var(--font-body, sans-serif);
    font-size: var(--text-sm, 0.875rem);
    font-weight: var(--font-weight-medium, 500);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--walnut);
    background: transparent;
    text-decoration: none;
    cursor: pointer;
    transition: background var(--duration-fast, 150ms), color var(--duration-fast, 150ms);
  }

  .pricing-card__cta:hover {
    background: var(--walnut);
    color: var(--parchment);
  }

  .pricing-card__cta--primary {
    background: var(--terracotta);
    color: var(--parchment);
    border-color: var(--terracotta);
  }

  .pricing-card__cta--primary:hover {
    background: var(--clay);
    border-color: var(--clay);
  }
</style>
