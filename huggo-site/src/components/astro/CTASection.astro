---
interface Props {
  title: string;
  subtitle?: string;
  ctaText: string;
  ctaHref: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  microText?: string;
  variant?: 'primary' | 'secondary';
}

const { title, subtitle, ctaText, ctaHref, secondaryCtaText, secondaryCtaHref, microText, variant = 'primary' } = Astro.props;
---

<section class:list={['cta-section', `cta-section--${variant}`]}>
  <div class="cta-section__inner">
    <h2 class="cta-section__title">{title}</h2>
    {subtitle && <p class="cta-section__subtitle">{subtitle}</p>}
    <div class="cta-section__actions">
      <a href={ctaHref} class:list={['cta-section__button', `cta-section__button--${variant}`]}>
        {ctaText}
      </a>
      {secondaryCtaText && secondaryCtaHref && (
        <a href={secondaryCtaHref} class="cta-section__button cta-section__button--outline">
          {secondaryCtaText}
        </a>
      )}
    </div>
    {microText && <p class="cta-section__micro-text">{microText}</p>}
  </div>
</section>

<style>
  .cta-section {
    padding: var(--space-section-y, 5rem) var(--space-6, 1.5rem);
    text-align: center;
    position: relative;
  }

  /* Primary — flat sage, no gradient */
  .cta-section--primary {
    background: var(--sage);
  }

  .cta-section--secondary {
    background: var(--parchment);
  }

  .cta-section__inner {
    max-width: 48rem;
    margin-inline: auto;
    position: relative;
    z-index: 1;
  }

  /* MCM rule accent above title */
  .cta-section__inner::before {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background-color: var(--terracotta);
    margin: 0 auto var(--space-6, 1.5rem);
  }

  .cta-section__title {
    font-family: var(--font-display, serif);
    font-size: var(--text-4xl, 2.625rem);
    font-weight: 400;
    line-height: var(--leading-tight, 1.15);
    letter-spacing: 0.02em;
    margin: 0 0 var(--space-4, 1rem);
  }

  .cta-section--primary .cta-section__title {
    color: var(--cream);
  }

  .cta-section--secondary .cta-section__title {
    color: var(--espresso);
  }

  .cta-section__subtitle {
    font-size: var(--text-lg, 1.125rem);
    line-height: 1.75;
    margin: 0 0 var(--space-8, 2rem);
    max-width: 36rem;
    margin-inline: auto;
  }

  .cta-section--primary .cta-section__subtitle {
    color: var(--parchment);
  }

  .cta-section--secondary .cta-section__subtitle {
    color: var(--walnut);
  }

  .cta-section__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4, 1rem);
    flex-wrap: wrap;
  }

  .cta-section__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4, 1rem) var(--space-10, 2.5rem);
    border-radius: 3px;
    font-family: var(--font-body, sans-serif);
    font-size: var(--text-base, 1rem);
    font-weight: var(--font-weight-medium, 500);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background var(--duration-fast, 150ms), color var(--duration-fast, 150ms);
  }

  /* On primary (sage) section: parchment button */
  .cta-section__button--primary {
    background: var(--parchment);
    color: var(--espresso);
  }

  .cta-section__button--primary:hover {
    background: var(--cream);
  }

  /* On secondary (parchment) section: terracotta CTA */
  .cta-section__button--secondary {
    background: var(--terracotta);
    color: var(--parchment);
  }

  .cta-section__button--secondary:hover {
    background: var(--clay);
  }

  /* Outline variant */
  .cta-section__button--outline {
    background: transparent;
    border: 1.5px solid var(--parchment);
    color: var(--parchment);
  }

  .cta-section--secondary .cta-section__button--outline {
    border-color: var(--walnut);
    color: var(--walnut);
  }

  .cta-section__button--outline:hover {
    background: var(--parchment);
    color: var(--espresso);
  }

  .cta-section--secondary .cta-section__button--outline:hover {
    background: var(--walnut);
    color: var(--parchment);
  }

  .cta-section__micro-text {
    font-size: var(--text-sm, 0.875rem);
    margin: var(--space-3, 0.75rem) 0 0;
    opacity: 0.75;
  }

  .cta-section--primary .cta-section__micro-text {
    color: var(--parchment);
  }

  .cta-section--secondary .cta-section__micro-text {
    color: var(--walnut);
  }
</style>
