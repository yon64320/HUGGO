---
interface Props {
  text: string;
  ctaText: string;
  ctaHref?: string;
}

const { text, ctaText, ctaHref = '#' } = Astro.props;
---

<section class="mascotte-section">
  <div class="mascotte-inner">
    <!-- Mascot visual placeholder -->
    <div class="mascotte-visual">
      <div class="mascotte-placeholder" aria-hidden="true">
        <svg width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="60" cy="60" r="56" fill="var(--color-green-primary, #4A9B4A)" opacity="0.12" />
          <circle cx="60" cy="60" r="40" fill="var(--color-green-primary, #4A9B4A)" opacity="0.2" />
          <rect x="40" y="35" width="40" height="35" rx="8" fill="var(--color-green-primary, #4A9B4A)" />
          <polygon points="50,70 56,80 58,70" fill="var(--color-green-primary, #4A9B4A)" />
          <text x="60" y="57" text-anchor="middle" font-family="var(--font-display, serif)" font-size="10" font-weight="700" fill="var(--parchment, #F9F4EA)">HUGGO</text>
          <!-- Eyes -->
          <circle cx="50" cy="48" r="3" fill="var(--parchment, #F9F4EA)" />
          <circle cx="70" cy="48" r="3" fill="var(--parchment, #F9F4EA)" />
          <circle cx="50" cy="48" r="1.5" fill="var(--color-green-dark, #3A7D3A)" />
          <circle cx="70" cy="48" r="1.5" fill="var(--color-green-dark, #3A7D3A)" />
        </svg>
      </div>
    </div>

    <!-- Text + CTA -->
    <div class="mascotte-content">
      <p class="mascotte-text">{text}</p>
      <a href={ctaHref} class="mascotte-cta">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        {ctaText}
      </a>
    </div>
  </div>
</section>

<style>
  .mascotte-section {
    padding: var(--space-12, 3rem) var(--space-6, 1.5rem);
    background: transparent;
  }

  .mascotte-inner {
    max-width: 48rem;
    margin-inline: auto;
    display: flex;
    align-items: center;
    gap: var(--space-8, 2rem);
  }

  .mascotte-visual {
    flex-shrink: 0;
  }

  .mascotte-placeholder {
    width: 120px;
    height: 120px;
  }

  .mascotte-content {
    flex: 1;
  }

  .mascotte-text {
    font-size: var(--text-lg, 1.125rem);
    color: var(--cream);
    line-height: var(--leading-relaxed, 1.7);
    margin: 0 0 var(--space-4, 1rem);
  }

  .mascotte-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2, 0.5rem);
    padding: var(--space-3, 0.75rem) var(--space-6, 1.5rem);
    background: linear-gradient(135deg, #2EE06F 0%, #25D366 50%, #1DA851 100%);
    color: var(--parchment);
    border-radius: var(--radius-btn, 10px);
    font-weight: var(--font-weight-semibold, 600);
    font-size: var(--text-base, 1rem);
    text-decoration: none;
    box-shadow: var(--shadow-inset-highlight), 0 2px 8px rgba(37, 211, 102, 0.3);
    transition:
      box-shadow var(--duration-hover, 250ms) var(--ease-premium),
      transform var(--duration-hover, 250ms) var(--ease-premium);
  }

  .mascotte-cta:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-inset-highlight), 0 4px 16px rgba(37, 211, 102, 0.4), 0 0 24px rgba(37, 211, 102, 0.2);
  }

  .mascotte-cta:active {
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .mascotte-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
