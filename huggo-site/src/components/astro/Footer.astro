---
import { mainNav, legalNav } from '@data/navigation';
import type { Locale } from '@i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const currentYear = new Date().getFullYear();

const footerLinks = mainNav.slice(0, 5); // Show first 5 nav items in footer

const socialLinks = [
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/company/huggo-app',
    icon: 'linkedin',
  },
  {
    name: 'Instagram',
    href: 'https://www.instagram.com/huggo.app',
    icon: 'instagram',
  },
  {
    name: 'Facebook',
    href: 'https://www.facebook.com/huggoapp',
    icon: 'facebook',
  },
];

const tagline = 'You chat, You go!';
const companyDesc: Record<Locale, string> = {
  fr: 'La solution de fid\u00E9lit\u00E9 digitale qui booste votre commerce via WhatsApp.',
  en: 'The digital loyalty solution that boosts your business via WhatsApp.',
};

const sectionTitles: Record<string, Record<Locale, string>> = {
  navigation: { fr: 'Navigation', en: 'Navigation' },
  legal: { fr: 'L\u00E9gal', en: 'Legal' },
  social: { fr: 'Suivez-nous', en: 'Follow us' },
};
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Column 1: Company info -->
    <div class="footer-col footer-col--brand">
      <a href={`/${locale}/`} class="footer-logo" aria-label="HUGGO">
        <svg width="100" height="30" viewBox="0 0 120 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2" y="4" width="32" height="24" rx="6" fill="var(--color-green-primary, #4A9B4A)" />
          <polygon points="10,28 16,34 18,28" fill="var(--color-green-primary, #4A9B4A)" />
          <text x="18" y="20" text-anchor="middle" font-family="var(--font-display, serif)" font-size="10" font-weight="700" fill="var(--parchment, #F9F4EA)">HUGGO</text>
          <text x="42" y="24" font-family="var(--font-display, serif)" font-size="18" font-weight="700" fill="var(--cream, #F5EDD8)">HUGGO</text>
        </svg>
      </a>
      <p class="footer-tagline">{tagline}</p>
      <p class="footer-desc">{companyDesc[locale]}</p>
    </div>

    <!-- Column 2: Navigation -->
    <div class="footer-col">
      <h3 class="footer-col__title">{sectionTitles.navigation[locale]}</h3>
      <ul class="footer-col__list">
        {footerLinks.map((item) => (
          <li>
            <a href={item.href[locale]} class="footer-col__link">
              {item.label[locale]}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 3: Legal -->
    <div class="footer-col">
      <h3 class="footer-col__title">{sectionTitles.legal[locale]}</h3>
      <ul class="footer-col__list">
        {legalNav.map((item) => (
          <li>
            <a href={item.href ? item.href[locale] : '#'} class="footer-col__link">
              {item.label[locale]}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 4: Social -->
    <div class="footer-col">
      <h3 class="footer-col__title">{sectionTitles.social[locale]}</h3>
      <ul class="footer-social">
        {socialLinks.map((link) => (
          <li>
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-social__link"
              aria-label={link.name}
            >
              {link.icon === 'linkedin' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              )}
              {link.icon === 'instagram' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" />
                </svg>
              )}
              {link.icon === 'facebook' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                </svg>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Copyright bar -->
  <div class="footer-copyright">
    <p>&copy; {currentYear} HUGGO. {locale === 'fr' ? 'Tous droits r\u00E9serv\u00E9s.' : 'All rights reserved.'}</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--moss);
    border-top: 1px solid var(--forest);
    padding-top: var(--space-16, 4rem);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-10, 2.5rem);
    max-width: 80rem;
    margin-inline: auto;
    padding: 0 var(--space-6, 1.5rem) var(--space-12, 3rem);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8, 2rem);
    }

    .footer-col--brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }

  .footer-logo {
    display: inline-block;
    margin-bottom: var(--space-3, 0.75rem);
  }

  .footer-tagline {
    font-family: var(--font-display, serif);
    font-size: var(--text-lg, 1.125rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--sage-light);
    margin: 0 0 var(--space-2, 0.5rem);
  }

  .footer-desc {
    font-size: var(--text-sm, 0.875rem);
    color: var(--parchment);
    line-height: 1.75;
    max-width: 28rem;
    margin: 0;
  }

  .footer-col__title {
    font-family: var(--font-body, sans-serif);
    font-size: var(--text-xs, 0.8125rem);
    font-weight: var(--font-weight-medium, 500);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--sage-light);
    margin: 0 0 var(--space-4, 1rem);
  }

  .footer-col__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 0.5rem);
  }

  .footer-col__link {
    font-size: var(--text-sm, 0.875rem);
    color: var(--parchment);
    text-decoration: none;
    transition: color var(--duration-fast, 150ms);
  }

  .footer-col__link:hover {
    color: var(--cream);
  }

  .footer-social {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-3, 0.75rem);
  }

  .footer-social__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 3px;
    background: var(--forest);
    color: var(--parchment);
    transition: background var(--duration-fast, 150ms), color var(--duration-fast, 150ms);
  }

  .footer-social__link:hover {
    background: var(--sage);
    color: var(--cream);
  }

  .footer-copyright {
    border-top: 1px solid var(--forest);
    padding: var(--space-4, 1rem) var(--space-6, 1.5rem);
    text-align: center;
  }

  .footer-copyright p {
    font-size: var(--text-xs, 0.8125rem);
    color: var(--sage-light);
    margin: 0;
  }
</style>
