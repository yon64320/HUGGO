---
import { stats } from '@data/stats';
import type { Locale } from '@i18n/config';

interface Props {
  locale: Locale;
  title?: string;
}

const { locale, title } = Astro.props;

const defaultTitle: Record<Locale, string> = {
  fr: 'Les chiffres parlent.',
  en: 'The numbers speak.',
};

const displayTitle = title || defaultTitle[locale];
---

<section class="stats-section" aria-label={displayTitle}>
  <div class="stats-inner">
    <h2 class="stats-section__title">{displayTitle}</h2>

    <div class="stats-grid">
      {stats.map((stat) => (
        <div class="stat-card">
          <div class="stat-card__number">
            <span
              class="stat-card__value"
              data-countup-target={stat.value}
              data-countup-suffix={stat.suffix}
              {...(stat.prefix ? { 'data-countup-prefix': stat.prefix } : {})}
            >
              {stat.prefix || ''}0{stat.suffix}
            </span>
          </div>
          <p class="stat-card__label">{stat.label[locale]}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from '../animations/gsap-init';

  document.querySelectorAll('.stat-card__value[data-countup-target]').forEach((el) => {
    const target = parseFloat(el.getAttribute('data-countup-target') || '0');
    const suffix = el.getAttribute('data-countup-suffix') || '';
    const prefix = el.getAttribute('data-countup-prefix') || '';

    const obj = { value: 0 };

    ScrollTrigger.create({
      trigger: el,
      start: 'top 85%',
      once: true,
      onEnter: () => {
        gsap.to(obj, {
          value: target,
          duration: 2,
          ease: 'power2.out',
          onUpdate: () => {
            const formatted = target % 1 === 0 ? Math.round(obj.value) : obj.value.toFixed(1);
            el.textContent = `${prefix}${formatted}${suffix}`;
          },
        });
      },
    });
  });
</script>

<style>
  .stats-section {
    padding: var(--space-section-y, 5rem) var(--space-6, 1.5rem);
  }

  .stats-inner {
    max-width: 80rem;
    margin-inline: auto;
    text-align: center;
  }

  .stats-section__title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: var(--text-3xl, 2rem);
    font-weight: var(--font-weight-bold, 700);
    color: var(--text-primary);
    margin: 0 0 var(--space-12, 3rem);
    letter-spacing: var(--tracking-tight, -0.02em);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8, 2rem);
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6, 1.5rem);
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6, 1.5rem);
    }
  }

  .stat-card {
    position: relative;
    overflow: hidden;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-card, 14px);
    padding: var(--space-8, 2rem) var(--space-6, 1.5rem);
    box-shadow: var(--shadow-inset-highlight-subtle), var(--shadow);
    transition:
      box-shadow var(--duration-hover, 250ms) var(--ease-premium),
      transform var(--duration-hover, 250ms) var(--ease-premium);
  }

  .stat-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(ellipse at 30% 0%, rgba(255,255,255,0.35) 0%, transparent 60%);
    pointer-events: none;
    z-index: 1;
  }

  .stat-card > * {
    position: relative;
    z-index: 2;
  }

  .stat-card:hover {
    box-shadow: var(--shadow-inset-highlight-subtle), var(--shadow-lg);
    transform: translateY(-4px);
  }

  .stat-card__number {
    margin-bottom: var(--space-2, 0.5rem);
  }

  .stat-card__value {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: var(--text-4xl, 2.625rem);
    font-weight: var(--font-weight-bold, 700);
    color: var(--forest);
    line-height: var(--leading-tight, 1.15);
    letter-spacing: var(--tracking-tight, -0.02em);
  }

  .stat-card__label {
    font-size: var(--text-sm, 0.875rem);
    color: var(--text-secondary);
    margin: 0;
    line-height: var(--leading-normal, 1.6);
  }
</style>
